# Clé pour protéger l'endpoint /analyze (à changer en production)
ANALYSIS_API_KEY=changeme

# Clé LLM — GitHub Models ou OpenAI
GITHUB_KEY=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# OPENAI_API_KEY=sk-xxxx

# URL de base LLM (GitHub Models par défaut)
LLM_BASE_URL=https://models.inference.ai.azure.com
# Pour OpenAI natif :
# LLM_BASE_URL=https://api.openai.com/v1

# Modèle à utiliser
LLM_MODEL=gpt-4o

# Timeout en secondes
LLM_TIMEOUT=120
