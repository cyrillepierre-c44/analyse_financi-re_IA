<%= turbo_stream.replace "analysis-frame" do %>
  <div id="analysis-frame" class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden mb-8">
    <div class="px-6 py-4 border-b border-gray-100 flex items-center justify-between">
      <div class="flex items-center gap-3">
        <span class="text-lg">🏦</span>
        <div>
          <h2 class="font-semibold text-gray-800">Analyse financière — Avis d'expert</h2>
          <% if @error %>
            <p class="text-xs text-rose-400 mt-0.5">Erreur lors de la génération</p>
          <% else %>
            <p class="text-xs text-gray-400 mt-0.5">
              Générée le <%= Time.current.strftime("%d/%m/%Y à %H:%M") %>
            </p>
          <% end %>
        </div>
      </div>
      <div class="flex items-center gap-2">
        <% unless @error %>
          <%= form_with url: company_analysis_path(@company), method: :post do |f| %>
            <%= f.hidden_field :force, value: "1" %>
            <%= f.submit "↺ Régénérer",
                class: "text-xs text-gray-500 hover:text-indigo-600 border border-gray-200 hover:border-indigo-300 px-3 py-1.5 rounded-lg cursor-pointer transition-colors",
                data: { disable_with: "En cours…" } %>
          <% end %>
        <% end %>
      </div>
    </div>

    <% if @error %>
      <div class="px-6 py-5 text-rose-700 text-sm bg-rose-50">
        <strong>Erreur :</strong> <%= @error %>
      </div>
    <% else %>
      <div class="px-6 py-6 prose prose-sm max-w-none text-gray-700 leading-relaxed analysis-content">
        <%= render_analysis(@analysis) %>
      </div>
      <div class="px-6 py-3 bg-gray-50 border-t border-gray-100 text-xs text-gray-400">
        Cette analyse est générée automatiquement par intelligence artificielle à partir des données
        comptables déclarées. Elle ne constitue pas un conseil en investissement.
      </div>
    <% end %>
  </div>
<% end %>
