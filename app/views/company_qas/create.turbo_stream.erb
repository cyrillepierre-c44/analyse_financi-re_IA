<%= turbo_stream.replace "qa-frame" do %>
  <% if @error %>
    <div id="qa-frame" class="bg-white rounded-xl border border-rose-200 shadow-sm overflow-hidden mb-8">
      <div class="px-6 py-4 border-b border-rose-100 flex items-center gap-3">
        <span class="text-lg">❓</span>
        <h2 class="font-semibold text-gray-800">Diagnostic rapide — Questions / Réponses</h2>
      </div>
      <div class="px-6 py-5 text-rose-700 text-sm bg-rose-50">
        <strong>Erreur :</strong> <%= @error %>
      </div>
    </div>
  <% else %>
    <%= render "companies/qa_section", company: @company %>
  <% end %>
<% end %>
